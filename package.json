    "test:clerk:full": "CLERK_E2E_FULL=true npx playwright test e2e/clerk.spec.js",
    "test:all:full": "STRIPE_E2E_FULL=true CLERK_E2E_FULL=true npx playwright test",
    "test:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
